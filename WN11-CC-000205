<#
.SYNOPSIS
    This PowerShell script ensures Windows 11 system is not sending "Full" diagnostic/telemetry data to Microsoft.

.NOTES
    Author          : Stephen Martinez
    LinkedIn        : www.linkedin.com/in/stephen-martinez20/
    GitHub          : github.com/stephenmartinez20
    Date Created    : 2026-05-25
    Last Modified   : 2026-05-25
    Version         : 5.1
    CVEs            : N/A
    Plugin IDs      : N/A
    STIG-ID         : WN11-CC-000205
    Documentation   : https://stigaview.com/products/win11/v2r7/WN11-CC-000205/

.TESTED ON
    Date(s) Tested  : 
    Tested By       : 
    Systems Tested  : 
    PowerShell Ver. : 

.USAGE
    Put any usage instructions here.
    Example syntax:
    PS C:\> .\STIG-ID-WN11-CC-000205.ps1 
#>

# Run PowerShell as Administrator

$registryPath = "HKLM:\SOFTWARE\Policies\Microsoft\Windows\DataCollection"
$valueName    = "AllowTelemetry"

# Valid STIG-compliant values:
# 0 = Security
# 1 = Basic
$valueData = 0

# Create the registry path if it does not exist
if (-not (Test-Path $registryPath)) {
    New-Item -Path $registryPath -Force | Out-Null
}

# Create or update the DWORD registry value
New-ItemProperty `
    -Path $registryPath `
    -Name $valueName `
    -Value $valueData `
    -PropertyType DWord `
    -Force | Out-Null

Write-Host "AllowTelemetry has been set to $valueData successfully."
